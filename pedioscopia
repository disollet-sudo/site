  }

  var btn = document.getElementById('btn-add');
  if(qtyAt > 0) { btn.textContent = "✓ Atualizar Quantidade"; btn.className = "btn-add adicionado"; }
  else { btn.textContent = "Adicionar ao pedido"; btn.className = "btn-add"; }

  document.getElementById('modal').classList.add('open');
}

function fecharModal() { document.getElementById('modal').classList.remove('open'); refModalAtivo = null; }
function clicouFora(e) { if(e.target.id === 'modal') fecharModal(); }

function mudaQtyModal(delta) {
  var inp = document.getElementById('modal-qty');
  var val = parseInt(inp.value) || 0;
  var p = catalogo.produtos.find(prod => normalizarReferencia(prod.codigo) === refModalAtivo);
  var step = p ? p.qtdEmbalagem : 1;
  val += (delta * step);
  if(val < step) val = step;
  inp.value = val;
}

function adicionarDoModal() {
  if(!refModalAtivo) return;
  var val = parseInt(document.getElementById('modal-qty').value) || 0;
  var p = catalogo.produtos.find(prod => normalizarReferencia(prod.codigo) === refModalAtivo);
  
  if(val > 0 && p && val % p.qtdEmbalagem !== 0) {
    val = Math.ceil(val / p.qtdEmbalagem) * p.qtdEmbalagem;
  }

  if(val <= 0) delete cesta[refModalAtivo];
  else cesta[refModalAtivo] = val;

  var card = document.getElementById(`card-${refModalAtivo}`);
  var bQty = document.getElementById(`badge-qty-${refModalAtivo}`);
  if(card) {
    if(val > 0) {
      card.classList.add('sel');
      if(bQty) { bQty.textContent = val; bQty.style.display = 'block'; }
    } else {
      card.classList.remove('sel');
      if(bQty) bQty.style.display = 'none';
    }
  }
  fecharModal();
  atualizarPainel();
  toast('Cesta atualizada!');
}

