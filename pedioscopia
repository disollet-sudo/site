  document.getElementById('modal-emb').textContent = 'Multiplicador Master: Múltiplos de ' + p.qtdEmbalagem + ' un';
  
  var qtyAt = cesta[ref] || 0;
  document.getElementById('modal-qty').value = qtyAt > 0 ? qtyAt : p.qtdEmbalagem;

  var img = document.getElementById('modal-img');
  var spin = document.getElementById('modal-spin');
  spin.style.display = 'block'; img.style.display = 'none';

  if(p.fileId) {
    img.src = `https://drive.google.com/thumbnail?id=${p.fileId}&sz=w600`;
    img.onload = () => { spin.style.display = 'none'; img.style.display = 'block'; };
  } else {
