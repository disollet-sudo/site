function salvarPedidoNuvem() {
  var razao = document.getElementById('cli-razao').value.trim();
  if(!razao) { alert('A Razão Social do cliente é obrigatória!'); return; }

  var client = {
    cnpj: document.getElementById('cli-cnpj').value.trim(),
    razao: razao,
    fantasia: document.getElementById('cli-fantasia').value.trim(),
    endereco: document.getElementById('cli-endereco').value.trim(),
    telefone: document.getElementById('cli-telefone').value.trim(),
    email: document.getElementById('cli-email').value.trim(),
    obs: document.getElementById('cli-obs').value.trim()
  };

  var stringItens = dadosAtuaisDoPedido.itens.map(i => `${i.codigo} (${i.qty}un)`).join(', ');

  var payload = {
    clienteInfo: `${client.razao} | CNPJ: ${client.cnpj || 'Isento'} | UF: ${dadosAtuaisDoPedido.uf} | Tel: ${client.telefone || '-'}`,
    itens: stringItens,
    qtd: dadosAtuaisDoPedido.qtd,
    subtotalProdutos: dadosAtuaisDoPedido.subtotalProdutos,
    totalIpi: dadosAtuaisDoPedido.totalIpi,
    totalDescontos: dadosAtuaisDoPedido.totalDescontos,
    valorFrete: dadosAtuaisDoPedido.valorFrete,
    prazo: dadosAtuaisDoPedido.prazo,
    total: dadosAtuaisDoPedido.total
  };

  var btn = document.getElementById(fluxoOrigem === 'd' ? 'btn-orc-d' : 'btn-orc-m');
  btn.disabled = true; btn.textContent = 'A guardar...';

  fecharModalCliente();
  toast('A registar pedido na folha...');

  fetch(URL_GOOGLE_SCRIPT + "?t=" + new Date().getTime(), {
    method: "POST",
    headers: { "Content-Type": "text/plain;charset=utf-8" },
    body: JSON.stringify(payload)
  })
  .then(res => res.json())
  .then(resData => {
    if(resData.status === 'success') {
      pedidoSalvo = true;
      clienteCompletoAtivo = client;
      toast('Pedido guardado com sucesso!');
      atualizarPainel();
    } else {
      alert('Erro: ' + resData.message);
      atualizarPainel();
    }
  })
  .catch(err => {
    console.error(err);
    toast('Erro de rede ao guardar.');
    atualizarPainel();
  });
}

function baixarPdf() {
  if(!pedidoSalvo || !dadosAtuaisDoPedido) { toast('Guarde o pedido primeiro!'); return; }
  toast('A compilar PDF...');

  var payloadPdf = {
    acao: 'pdf',
    dadosPdf: {
      cliente: clienteCompletoAtivo,
      itens: dadosAtuaisDoPedido.itens,
      contas: {
        subtotal: dadosAtuaisDoPedido.subtotalProdutos,
        valPrazo: dadosAtuaisDoPedido.totalDescontos,
        prazo: dadosAtuaisDoPedido.pctPrazo,
        totalIpi: dadosAtuaisDoPedido.totalIpi,
        valorFrete: dadosAtuaisDoPedido.valorFrete,
        uf: dadosAtuaisDoPedido.uf,
        liquido: dadosAtuaisDoPedido.total,
        tabelaAtiva: 'ICMS ' + dadosAtuaisDoPedido.tabelaAtiva
      }
    }
  };

  fetch(URL_GOOGLE_SCRIPT, {
    method: 'POST',
    headers: { 'Content-Type': 'text/plain;charset=utf-8' },
    body: JSON.stringify(payloadPdf)
  })
  .then(res => res.json())
  .then(resData => {
    if(resData.status === 'success' && resData.base64) {
      var byteChars = atob(resData.base64);
      var byteNumbers = new Array(byteChars.length);
      for (var i = 0; i < byteChars.length; i++) { byteNumbers[i] = byteChars.charCodeAt(i); }
      var blob = new Blob([new Uint8Array(byteNumbers)], { type: 'application/pdf' });
      
      var link = document.createElement('a');
      link.href = window.URL.createObjectURL(blob);
      link.download = `Pedido_${clienteCompletoAtivo.razao.replace(/[^a-z0-9]/gi, '_')}.pdf`;
      link.click();
      toast('PDF descarregado!');
    } else {
      alert('Erro na geração: ' + resData.message);
    }
  })
  .catch(err => { console.error(err); toast('Erro ao chamar motor PDF.'); });
}

function toast(msg) {
  var t = document.getElementById('toast');
  t.textContent = msg; t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 3000);
}
</script>
