// CÁLCULO CORE: REGRAS DE PRODUTOS E FRETE POR ESTADO
// ─────────────────────────────────────────────
function atualizarPainel() {
  var tabelaAtiva = document.getElementById('icms-d').value;
  var pctPrazo = parseInt(document.getElementById('prazo-d').value) || 0;
  var ufAtiva = document.getElementById('uf-d').value;

  var subtotal = 0;
  var totalIpi = 0;
  var totalItensQtd = 0;
  var htmlLista = '';
  var itensArray = [];

  for (var ref in cesta) {
    var qty = cesta[ref];
    if(qty <= 0) continue;

    var p = catalogo.produtos.find(prod => normalizarReferencia(prod.codigo) === ref);
    if(!p) continue;

    var precoUn = p.precos[tabelaAtiva] || p.precos['ICMS ' + tabelaAtiva] || Object.values(p.precos)[0] || 0;
    if (p.emPromocao) {
      precoUn = p.precosPromo[tabelaAtiva] || p.precosPromo['ICMS ' + tabelaAtiva] || Object.values(p.precosPromo)[0] || precoUn;
    }

    var totalItem = precoUn * qty;
    var ipiItem = totalItem * ((p.ipi || 0) / 100);

    subtotal += totalItem;
    totalIpi += ipiItem;
    totalItensQtd += qty;

    itensArray.push({
      codigo: p.codigo,
      descricao: p.descricao,
      emb: p.qtdEmbalagem,
      qty: qty,
      preco: precoUn,
      ipi: p.ipi,
      totalItem: totalItem
    });

    htmlLista += `
      <div class="sel-row">
        <div class="sel-cod" title="${p.codigo}">${p.codigo}</div>
        <div class="sel-desc" title="${p.descricao}">${p.descricao}</div>
        <div class="sel-qty-wrap">
          <button class="qty-btn" onclick="mudaQtyCesta('${ref}', -1)">−</button>
          <span class="qty-num">${qty}</span>
          <button class="qty-btn" onclick="mudaQtyCesta('${ref}', 1)">+</button>
        </div>
        <div class="sel-rm" onclick="removeCesta('${ref}')">&times;</div>
      </div>
    `;
  }

  if (totalItensQtd === 0) {
    var vHtml = '<div class="vazio">Nenhum produto selecionado</div>';
    document.getElementById('lista-d').innerHTML = vHtml;
    document.getElementById('lista-m').innerHTML = vHtml;
    
    ['rd','rm'].forEach(pfx => {
      document.getElementById(`${pfx}-bruto-prod`).textContent = 'R$ 0,00';
      document.getElementById(`${pfx}-prazo-val`).textContent = '- R$ 0,00';
      document.getElementById(`${pfx}-ipi-val`).textContent = '+ R$ 0,00';
      document.getElementById(`${pfx}-frete-val`).textContent = 'Selecione o Estado';
      document.getElementById(`${pfx}-frete-val`).style.color = 'var(--texto)';
      document.getElementById(`${pfx}-total`).textContent = 'R$ 0,00';
      document.getElementById(`btn-orc-${pfx.slice(-1)}`).disabled = true;
      document.getElementById(`btn-orc-${pfx.slice(-1)}`).textContent = 'Finalizar e Salvar Pedido';
      document.getElementById(`btn-xls-${pfx.slice(-1)}`).disabled = true;
      document.getElementById(`btn-xls-${pfx.slice(-1)}`).className = 'btn pdf-btn';
    });
    
    document.getElementById('badge').style.display = 'none';
    document.getElementById('mob-bar').style.display = 'none';
    return;
  }

  document.getElementById('lista-d').innerHTML = htmlLista;
  document.getElementById('lista-m').innerHTML = htmlLista;

  var valPrazo = subtotal * (pctPrazo / 100);
  
  // 🚚 Lógica de Precificação de Frete e Validação Restritiva
  var valorFrete = 0;
  var freteTxt = 'Grátis';
  var freteBloqueado = false;

  if (!ufAtiva) {
    freteTxt = 'Selecione o Estado';
    freteBloqueado = true;
  } else if (catalogo.fretes && catalogo.fretes[ufAtiva]) {
    var regra = catalogo.fretes[ufAtiva];
    
    if (subtotal < regra.minimoPedido) {
      freteTxt = `Abaixo do Limite (Min: R$ ${fmt(regra.minimoPedido)})`;
      freteBloqueado = true;
    } else if (subtotal >= regra.freteGratis) {
      valorFrete = 0;
      freteTxt = 'Grátis';
    } else {
      valorFrete = regra.valorFrete;
      freteTxt = `R$ ${fmt(valorFrete)}`;
    }
  } else {
    freteTxt = 'Grátis (Sem regra)';
    valorFrete = 0;
  }

  var liquido = subtotal - valPrazo + totalIpi + valorFrete;

  // Atualização síncrona UI Desktop e Mobile
  ['rd','rm'].forEach(pfx => {
    document.getElementById(`${pfx}-bruto-prod`).textContent = 'R$ ' + fmt(subtotal);
    document.getElementById(`${pfx}-prazo-pct`).textContent = pctPrazo;
    document.getElementById(`${pfx}-prazo-val`).textContent = '- R$ ' + fmt(valPrazo);
    document.getElementById(`${pfx}-ipi-val`).textContent = '+ R$ ' + fmt(totalIpi);
    document.getElementById(`${pfx}-frete-val`).textContent = freteTxt;
    document.getElementById(`${pfx}-total`).textContent = 'R$ ' + fmt(liquido);

    var btnFecho = document.getElementById(`btn-orc-${pfx.slice(-1)}`);
    if(freteBloqueado) {
      document.getElementById(`${pfx}-frete-val`).style.color = '#e24b4a';
      document.getElementById(`${pfx}-frete-val`).style.fontWeight = 'bold';
      btnFecho.disabled = true;
      btnFecho.textContent = ufAtiva ? 'Abaixo do Limite Mínimo' : 'Selecione o Estado';
    } else {
      document.getElementById(`${pfx}-frete-val`).style.color = valorFrete > 0 ? 'var(--texto)' : 'var(--verde-dk)';
      btnFecho.disabled = false;
      btnFecho.textContent = 'Finalizar e Salvar Pedido';
    }

    var btnPdf = document.getElementById(`btn-xls-${pfx.slice(-1)}`);
    if(pedidoSalvo) {
      btnPdf.disabled = false;
      btnPdf.className = 'btn pdf-btn liberado';
    } else {
      btnPdf.disabled = true;
      btnPdf.className = 'btn pdf-btn';
    }
  });

  document.getElementById('badge').textContent = `${totalItensQtd} itens`;
  document.getElementById('badge').style.display = 'block';
  
  document.getElementById('mob-bar').style.display = 'flex';
  document.getElementById('mb-info').innerHTML = `<b>Total: R$ ${fmt(liquido)}</b><br>${totalItensQtd} itens`;

  dadosAtuaisDoPedido = {
    itens: itensArray,
    subtotalProdutos: subtotal,
    totalIpi: totalIpi,
    totalDescontos: valPrazo,
    pctPrazo: pctPrazo,
    valorFrete: valorFrete,
    uf: ufAtiva,
    prazo: document.getElementById('prazo-d').options[document.getElementById('prazo-d').selectedIndex].text,
    tabelaAtiva: tabelaAtiva,
    total: liquido,
    qtd: totalItensQtd
  };
}

function mudaQtyCesta(ref, delta) {
  var p = catalogo.produtos.find(prod => normalizarReferencia(prod.codigo) === ref);
  if(!p) return;
  var step = p.qtdEmbalagem || 1;
  
  if(!cesta[ref]) cesta[ref] = 0;
  cesta[ref] += (delta * step);
  
  if(cesta[ref] <= 0) delete cesta[ref];
  
  var bQty = document.getElementById(`badge-qty-${ref}`);
  var card = document.getElementById(`card-${ref}`);
  if(card) {
    if(cesta[ref] > 0) {
      card.classList.add('sel');
      if(bQty) { bQty.textContent = cesta[ref]; bQty.style.display = 'block'; }
    } else {
      card.classList.remove('sel');
      if(bQty) bQty.style.display = 'none';
    }
  }
  atualizarPainel();
}

function removeCesta(ref) {
  delete cesta[ref];
  var card = document.getElementById(`card-${ref}`);
  var bQty = document.getElementById(`badge-qty-${ref}`);
  if(card) card.classList.remove('sel');
  if(bQty) bQty.style.display = 'none';
  atualizarPainel();
}

function limSel() {
  if(confirm("Deseja realmente limpar toda a sua cesta?")) {
    cesta = {};
    pedidoSalvo = false;
    document.querySelectorAll('.card').forEach(c => c.classList.remove('sel'));
    document.querySelectorAll('.card-badge-qty').forEach(b => b.style.display = 'none');
    atualizarPainel();
  }
}

