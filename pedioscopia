<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>Di Solle</title>
<link rel="icon" type="image/png" href="https://drive.google.com/thumbnail?id=1mS6_4Yv74x6tq7B10kZz2m7FndNly7gq&sz=w64">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{--verde:#1D9E75;--verde-lt:#E1F5EE;--verde-dk:#0F6E56;--cinza:#f4f4f2;--borda:#e0dfd8;--texto:#1a1a18;--sub:#6b6b65;--branco:#fff;--promo:#E24B4A}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;background:var(--cinza);color:var(--texto);font-size:14px;line-height:1.5;padding-bottom:80px}

/* HEADER */
header{background:#000;border-bottom:1px solid #222;padding:12px 20px;position:sticky;top:0;z-index:200}
.header-inner{max-width:1200px;margin:0 auto;display:flex;align-items:center;gap:14px}
.logo-area{flex-shrink:0;display:flex;align-items:center}
.logo-area img{max-height:48px;display:block}
.search-wrap{flex:1;position:relative;max-width:500px}
.search-wrap input{width:100%;padding:10px 12px 10px 36px;border:1px solid #444;border-radius:8px;font-size:14px;background:#222;color:#fff;outline:none}
.search-wrap input:focus{border-color:var(--verde)}
.search-icon{position:absolute;left:11px;top:50%;transform:translateY(-50%);color:#888;font-size:15px;pointer-events:none}
.badge{background:var(--verde);color:#fff;border-radius:20px;padding:5px 12px;font-size:12px;font-weight:700;white-space:nowrap;display:none}

/* FILTROS E SYNC */
.filtros{background:var(--branco);border-bottom:1px solid var(--borda);padding:8px 20px}
.filtros-inner{max-width:1200px;margin:0 auto;display:flex;gap:8px;flex-wrap:wrap;align-items:center}
.filtros-inner label{font-size:12px;color:var(--sub);font-weight:600}
.filtros-inner select,.filtros-inner input[type=number]{padding:5px 8px;border:1px solid var(--borda);border-radius:6px;font-size:12px;background:var(--cinza);outline:none}
.btn-lim{padding:5px 10px;border:1px solid var(--borda);border-radius:6px;background:var(--branco);font-size:12px;cursor:pointer;color:var(--sub)}
.btn-lim:hover{border-color:var(--verde);color:var(--verde)}
.btn-sync{background:#E1F5EE;color:var(--verde-dk);border:1px solid var(--verde);font-weight:700;}
.btn-sync:hover{background:var(--verde);color:#fff;}
.top-actions{margin-left:auto; display:flex; align-items:center; gap:12px;}

/* LAYOUT */
.main{max-width:1200px;margin:0 auto;padding:16px 20px;display:grid;grid-template-columns:1fr 350px;gap:16px;align-items:start}
@media(max-width:880px){.main{grid-template-columns:1fr;padding:10px} .top-actions{margin-left:0; width:100%; justify-content:space-between; margin-top:5px;}}

/* GRID E CARDS */
.grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(170px,1fr));gap:12px}
@media(max-width:500px){.grid{grid-template-columns:repeat(2,1fr);gap:8px}}
.card{background:var(--branco);border:1.5px solid var(--borda);border-radius:10px;overflow:hidden;position:relative;display:flex;flex-direction:column;cursor:pointer;transition:border-color .15s,box-shadow .15s}
.card.sel{border-color:var(--verde);border-width:2px;box-shadow:0 0 0 3px rgba(29,158,117,.13)}
.card.promo{border: 2px solid var(--promo) !important; background: #FFF4F4 !important;}
.card-badge-promo{position:absolute;top:7px;right:7px;background:var(--promo);color:#fff;border-radius:4px;padding:3px 7px;font-size:10px;font-weight:800;}
.card-badge-qty{position:absolute;top:7px;left:7px;background:var(--verde);color:#fff;border-radius:12px;padding:2px 8px;font-size:11px;font-weight:700;display:none;}
.card.sel .card-badge-qty{display:block}
.card-img{width:100%;height:145px;background:var(--cinza);display:flex;align-items:center;justify-content:center;overflow:hidden;}
.card-img img{width:100%;height:100%;object-fit:contain;opacity:0;transition:opacity .3s}
.card-img img.loaded{opacity:1}
.no-img-icon{font-size:30px;color:#ddd}

/* SKELETON */
.sk-card{background:var(--branco);border:1.5px solid var(--borda);border-radius:10px;overflow:hidden}
.skeleton{background:linear-gradient(90deg,#eee 25%,#f5f5f5 50%,#eee 75%);background-size:200% 100%;animation:shimmer 1.2s infinite;border-radius:4px}
@keyframes shimmer{0%{background-position:200% 0}100%{background-position:-200% 0}}

.card-body{padding:10px 12px 12px}
.card-cod{font-size:11px;font-weight:700;color:var(--verde-dk);margin-bottom:3px}
.card-desc{font-size:12px;color:var(--texto);font-weight:500;line-height:1.35;margin-bottom:6px;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
.card-bottom{display:flex;justify-content:space-between;align-items:center}
.card-preco{font-size:15px;font-weight:800;color:var(--verde-dk)}
.card-emb{font-size:11px;background:var(--cinza);padding:2px 6px;border-radius:4px;color:var(--sub)}

/* PAINEL E MODALS */
.painel{background:var(--branco);border:1px solid var(--borda);border-radius:12px;padding:18px;position:sticky;top:90px}
.painel h3{font-size:14px;font-weight:600;margin-bottom:14px;display:flex;align-items:center;gap:7px}
.field{margin-bottom:12px}
.field label{display:block;font-size:12px;color:var(--sub);margin-bottom:4px;font-weight:600}
.field select, .field input[type=text], .field input[type=email], .field textarea{width:100%;padding:8px 10px;border:1px solid var(--borda);border-radius:7px;font-size:13px;outline:none;background:#fff;color:var(--texto)}
.lista-sel{max-height:180px;overflow-y:auto;border:1px solid var(--borda);border-radius:8px;margin-bottom:12px}
.sel-row{display:flex;align-items:center;padding:7px 10px;border-bottom:1px solid var(--borda);gap:6px}
.sel-row:last-child{border-bottom:none}
.sel-cod{font-size:11px;font-weight:700;color:var(--verde-dk);flex-shrink:0;width:70px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.sel-desc{flex:1;font-size:11px;color:var(--sub);overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.sel-qty-wrap{display:flex;align-items:center;gap:4px;flex-shrink:0}
.qty-btn{width:22px;height:22px;border:1px solid var(--borda);border-radius:5px;background:var(--cinza);cursor:pointer;font-size:14px;font-weight:700;display:flex;align-items:center;justify-content:center}
.qty-num{width:32px;text-align:center;font-size:12px;font-weight:700}
.sel-rm{cursor:pointer;color:#ccc;font-size:18px;flex-shrink:0}
.sel-rm:hover{color:#e24b4a}
.vazio{text-align:center;padding:18px;color:var(--sub);font-size:12px}

.btn{width:100%;padding:11px;border:1px solid var(--borda);border-radius:8px;font-size:13px;cursor:pointer;font-weight:600;display:flex;align-items:center;justify-content:center;gap:6px;transition:all .15s;margin-bottom:8px;background:var(--branco);color:var(--texto)}
.btn:hover{border-color:var(--verde);color:var(--verde)}
.btn.prim{background:var(--verde);border-color:var(--verde);color:#fff}
.btn.prim:hover{background:var(--verde-dk)}
.btn.pdf-btn{background:#f0f0ed;color:#aaa;border-color:#ddd;cursor:not-allowed}
.btn.pdf-btn.liberado{background:#fff;color:var(--verde-dk);border-color:var(--verde);cursor:pointer}
.btn.pdf-btn.liberado:hover{background:var(--verde-lt)}
.btn:disabled{opacity:.5;cursor:not-allowed;background-color:#eee !important;color:#999 !important}

.resultado{background:var(--verde-lt);border:1px solid #9FE1CB;border-radius:8px;padding:12px;margin-bottom:12px}
.res-row{display:flex;justify-content:space-between;margin-bottom:5px;font-size:13px}
.res-row span:first-child{color:var(--texto);font-weight:500}
.res-row b{color:var(--verde-dk)}
.res-sep{border-top:1px solid #9FE1CB;margin:6px 0}

.mob-bar{display:none;position:fixed;bottom:0;left:0;right:0;background:var(--branco);border-top:1px solid var(--borda);padding:10px 16px;z-index:150;align-items:center;gap:10px}
.mob-bar .mb-info{flex:1;font-size:13px;line-height:1.3}
.mob-bar .mb-btn{padding:10px 18px;background:var(--verde);color:#fff;border:none;border-radius:8px;font-size:13px;font-weight:700}
@media(max-width:880px){.mob-bar{display:flex}.painel{display:none}}

.sh-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:300}
.sh-overlay.open{display:block}
.b-sheet{position:fixed;bottom:0;left:0;right:0;background:var(--branco);border-radius:16px 16px 0 0;padding:16px 16px 24px;z-index:400;transform:translateY(100%);transition:transform .3s ease;max-height:88vh;overflow-y:auto}
.b-sheet.open{transform:translateY(0)}
.sh-handle{width:40px;height:4px;background:#ddd;border-radius:2px;margin:0 auto 14px}
.sh-title{font-size:15px;font-weight:600;margin-bottom:14px}

.modal{display:none;position:fixed;inset:0;background:rgba(0,0,0,.85);z-index:500;justify-content:center;align-items:center;padding:16px}
.modal.open{display:flex}
.modal-box{background:var(--branco);border-radius:14px;overflow:hidden;width:100%;max-width:480px;max-height:94vh;display:flex;flex-direction:column}
.modal-img-wrap{background:#fff;display:flex;align-items:center;justify-content:center;height:320px;position:relative;padding:8px}
.modal-img-wrap img{width:100%;height:100%;object-fit:contain}
.modal-spin{width:32px;height:32px;border:3px solid #ddd;border-top-color:var(--verde);border-radius:50%;animation:spin .7s linear infinite}
@keyframes spin{to{transform:rotate(360deg)}}
.modal-close-btn{position:absolute;top:10px;right:12px;width:30px;height:30px;background:rgba(0,0,0,.35);border:none;border-radius:50%;color:#fff;font-size:18px;cursor:pointer;display:flex;align-items:center;justify-content:center}
.modal-info{padding:14px 18px;overflow-y:auto}
.modal-cod{font-size:12px;font-weight:700;color:var(--verde-dk);margin-bottom:3px}
.modal-desc{font-size:15px;font-weight:600;line-height:1.4;margin-bottom:4px}
.modal-preco{font-size:20px;font-weight:800;color:var(--verde-dk);margin-bottom:4px}
.modal-emb{font-size:12px;color:var(--sub);margin-bottom:14px;background:var(--verde-lt);padding:4px 8px;border-radius:4px;display:inline-block}
.qty-row{display:flex;align-items:center;margin-bottom:14px}
.qty-row label{font-size:13px;color:var(--sub);margin-right:10px;font-weight:500}
.qty-big-btn{width:36px;height:36px;border:1.5px solid var(--borda);background:var(--cinza);cursor:pointer;font-size:20px;font-weight:700;display:flex;align-items:center;justify-content:center}
.qty-big-btn:first-of-type{border-radius:8px 0 0 8px}
.qty-big-btn:last-of-type{border-radius:0 8px 8px 0}
.qty-big-input{width:65px;height:36px;border:1.5px solid var(--borda);border-left:none;border-right:none;text-align:center;font-size:16px;font-weight:700;outline:none}
.btn-add{width:100%;padding:13px;background:var(--verde);border:none;border-radius:10px;color:#fff;font-size:15px;font-weight:700;cursor:pointer}
.btn-add.adicionado{background:var(--verde-dk)}

.toast{position:fixed;bottom:76px;right:16px;background:#1a1a18;color:#fff;padding:10px 16px;border-radius:8px;font-size:13px;opacity:0;transform:translateY(6px);transition:all .2s;pointer-events:none;z-index:999}
.toast.show{opacity:1;transform:translateY(0)}
@media(min-width:881px){.toast{bottom:20px}}
</style>
</head>
<body>

<header>
  <div class="header-inner">
    <div class="logo-area" id="logo-area">
      <img src="https://drive.google.com/thumbnail?id=1mS6_4Yv74x6tq7B10kZz2m7FndNly7gq&sz=w300" alt="Di Solle">
    </div>
    <div class="search-wrap">
      <span class="search-icon">&#128269;</span>
      <input type="text" id="busca" placeholder="Código, descrição ou EAN..." oninput="filtrar()">
    </div>
    <div class="badge" id="badge">0 itens</div>
  </div>
</header>

<div class="filtros">
  <div class="filtros-inner">
    <label>MARCA:</label>
    <select id="fil-marca" onchange="filtrar()"><option value="">TODAS</option></select>
    <label>PREÇO ATÉ:</label>
    <input type="number" id="fil-preco" placeholder="R$" oninput="filtrar()" style="width:80px">
    <button class="btn-lim" onclick="limFiltros()">✕ Limpar</button>
    
    <div class="top-actions">
      <span style="font-size:12px;color:var(--sub)" id="cont"></span>
      <button class="btn-lim btn-sync" id="btn-sync" onclick="sincronizarPlanilha()">🔄 Sincronizar Catálogo</button>
    </div>
  </div>
</div>

<div class="main">
  <div>
    <div id="grid" class="grid"></div>
  </div>
  
  <aside class="painel">
    <h3>📊 Fechamento do Pedido</h3>
    <div class="lista-sel" id="lista-d"></div>
    
    <div class="field">
      <label>Estado (UF) para Regra de Frete</label>
      <select id="uf-d" onchange="syncRegras('uf-d','uf-m')">
        <option value="">Selecione o Estado...</option>
      </select>
    </div>

    <div class="field">
      <label>Regra de ICMS / Faixa</label>
      <select id="icms-d" onchange="syncRegras('icms-d','icms-m')">
        <option value="7">ICMS 7</option>
        <option value="12">ICMS 12</option>
      </select>
    </div>
    
    <div class="field">
      <label>Prazo de Pagamento</label>
      <select id="prazo-d" onchange="syncRegras('prazo-d','prazo-m')">
        <option value="14">Antecipado (-14%)</option>
        <option value="9">28 dias (-9%)</option>
        <option value="7">35 dias (-7%)</option>
        <option value="5">42 dias (-5%)</option>
        <option value="2">56 dias (-2%)</option>
        <option value="0">63 dias (0%)</option>
      </select>
    </div>

    <div class="resultado">
      <div class="res-row"><span>Subtotal Itens:</span><b id="rd-bruto-prod">R$ 0,00</b></div>
      <div class="res-row"><span>Desc. de Volume:</span><b id="rd-icms-val" style="color:var(--verde-dk);">Incluso na Tabela</b></div>
      <div class="res-row"><span>Desc. Prazo (<span id="rd-prazo-pct">0</span>%):</span><b id="rd-prazo-val" style="color:#c0392b;">- R$ 0,00</b></div>
      <div class="res-row"><span>Valor Total IPI (+):</span><b id="rd-ipi-val" style="color:#2980b9;">+ R$ 0,00</b></div>
      <div class="res-row"><span>Valor Frete:</span><b id="rd-frete-val">Selecione o Estado</b></div>
      <div class="res-sep"></div>
      <div class="res-row" style="font-size:15px"><span>TOTAL LÍQUIDO:</span><b id="rd-total">R$ 0,00</b></div>
    </div>
    
    <button class="btn prim" id="btn-orc-d" onclick="abrirFluxoFechamento('d')" disabled>Finalizar e Salvar Pedido</button>
    <button class="btn pdf-btn" id="btn-xls-d" onclick="baixarPdf()" disabled>📄 PDF (Guardar p/ Liberar)</button>
    <button class="btn" onclick="limSel()">Limpar seleção</button>
  </aside>
</div>

<div class="mob-bar" id="mob-bar">
  <div class="mb-info" id="mb-info">Selecione produtos</div>
  <button class="mb-btn" onclick="abrirSheet()">Ver resumo</button>
</div>

<div class="sh-overlay" id="sh-ov" onclick="fecharSheet()"></div>

<div class="b-sheet" id="b-sheet">
  <div class="sh-handle"></div>
  <div class="sh-title">📊 Fechamento do Pedido</div>
  <div class="lista-sel" id="lista-m" style="margin-bottom:12px"></div>
  
  <div class="field">
    <label>Estado (UF) para Regra de Frete</label>
    <select id="uf-m" onchange="syncRegras('uf-m','uf-d')">
      <option value="">Selecione o Estado...</option>
    </select>
  </div>

  <div class="field">
    <label>Regra de ICMS / Faixa</label>
    <select id="icms-m" onchange="syncRegras('icms-m','icms-d')">
      <option value="7">ICMS 7</option>
      <option value="12">ICMS 12</option>
    </select>
  </div>
  
  <div class="field">
    <label>Prazo de Pagamento</label>
    <select id="prazo-m" onchange="syncRegras('prazo-m','prazo-d')">
      <option value="14">Antecipado (-14%)</option>
      <option value="9">28 dias (-9%)</option>
      <option value="7">35 dias (-7%)</option>
      <option value="5">42 dias (-5%)</option>
      <option value="2">56 dias (-2%)</option>
      <option value="0">63 dias (0%)</option>
    </select>
  </div>

  <div class="resultado">
    <div class="res-row"><span>Subtotal Itens:</span><b id="rm-bruto-prod">R$ 0,00</b></div>
    <div class="res-row"><span>Desc. de Volume:</span><b id="rm-icms-val" style="color:var(--verde-dk);">Incluso na Tabela</b></div>
    <div class="res-row"><span>Desc. Prazo (<span id="rm-prazo-pct">0</span>%):</span><b id="rm-prazo-val" style="color:#c0392b;">- R$ 0,00</b></div>
    <div class="res-row"><span>Valor Total IPI (+):</span><b id="rm-ipi-val" style="color:#2980b9;">+ R$ 0,00</b></div>
    <div class="res-row"><span>Valor Frete:</span><b id="rm-frete-val">Selecione o Estado</b></div>
    <div class="res-sep"></div>
    <div class="res-row" style="font-size:15px"><span>TOTAL LÍQUIDO:</span><b id="rm-total">R$ 0,00</b></div>
  </div>

  <button class="btn prim" id="btn-orc-m" onclick="abrirFluxoFechamento('m')" disabled>Finalizar e Salvar Pedido</button>
  <button class="btn pdf-btn" id="btn-xls-m" onclick="baixarPdf()" disabled>📄 PDF (Guardar p/ Liberar)</button>
  <button class="btn" onclick="limSel();fecharSheet()">Limpar seleção</button>
  <button class="btn" onclick="fecharSheet()">Fechar</button>
</div>

<div class="modal" id="modal" onclick="clicouFora(event)">
  <div class="modal-box" id="modal-box">
    <div class="modal-img-wrap" id="modal-img-wrap">
      <div class="modal-spin" id="modal-spin"></div>
      <img id="modal-img" src="" alt="" style="display:none">
      <button class="modal-close-btn" onclick="fecharModal()">&times;</button>
    </div>
    <div class="modal-info">
      <div class="modal-cod" id="modal-cod"></div>
      <div class="modal-desc" id="modal-desc"></div>
      <div class="modal-preco" id="modal-preco"></div>
      <div class="modal-emb" id="modal-emb"></div>
      <div class="qty-row">
        <label>Quantidade:</label>
        <button class="qty-big-btn" onclick="mudaQtyModal(-1)">&#8722;</button>
        <input class="qty-big-input" type="number" id="modal-qty" value="1" min="1">
        <button class="qty-big-btn" onclick="mudaQtyModal(1)">&#43;</button>
      </div>
      <button class="btn-add" id="btn-add" onclick="adicionarDoModal()">Adicionar ao pedido</button>
    </div>
  </div>
</div>

<div class="modal" id="modal-cliente" onclick="clicouForaCliente(event)">
  <div class="modal-box" style="max-width:460px; max-height:90vh;">
    <div style="padding:14px 18px; border-bottom:1px solid var(--borda); display:flex; justify-content:space-between; align-items:center; background:var(--cinza)">
      <b style="font-size:15px; color:var(--texto)">🏢 Dados Cadastrais do Cliente</b>
      <button onclick="fecharModalCliente()" style="background:none; border:none; font-size:22px; cursor:pointer; color:var(--sub)">&times;</button>
    </div>
    <div class="modal-info" style="padding:16px 18px; display:flex; flex-direction:column; gap:2px;">
      <div class="field"><label>CNPJ</label><input type="text" id="cli-cnpj" placeholder="00.000.000/0001-00"></div>
      <div class="field"><label>RAZÃO SOCIAL</label><input type="text" id="cli-razao" placeholder="Razão Social"></div>
      <div class="field"><label>FANTASIA</label><input type="text" id="cli-fantasia" placeholder="Nome Fantasia"></div>
      <div class="field"><label>ENDEREÇO</label><input type="text" id="cli-endereco" placeholder="Endereço Completo"></div>
      <div class="field"><label>TELEFONE</label><input type="text" id="cli-telefone" placeholder="(00) 00000-0000"></div>
      <div class="field"><label>E-MAIL</label><input type="email" id="cli-email" placeholder="cliente@email.com"></div>
      <div class="field"><label>OBSERVAÇÃO</label><textarea id="cli-obs" placeholder="Observações..." style="height:60px; resize:none; font-family:inherit;"></textarea></div>
      <button class="btn prim" onclick="salvarPedidoNuvem()" style="margin-top:10px; padding:13px;">Confirmar e Enviar Pedido</button>
    </div>
  </div>
</div>

<div class="toast" id="toast"></div>

<script>
// Ajusta automaticamente a URL correta da Web App do Script
var URL_GOOGLE_SCRIPT = "https://script.google.com/macros/s/AKfycbzMCt2Ydh7KG0V_AqowG5vdp0rD9_hPm7yKwpolJ4wSlIm4XaUD88AIC6Cu0VgG5YI1dw/exec"; 
if(window.location.href.includes("script.google.com")) {
  URL_GOOGLE_SCRIPT = window.location.href.split('/exec')[0] + '/exec';
}

var catalogo = { produtos: [], logoUrl: "", fretes: {} };
var cesta = {};
var refModalAtivo = null;
var fluxoOrigem = 'd';
var pedidoSalvo = false;
var clienteCompletoAtivo = null;
var dadosAtuaisDoPedido = null;

function normalizarReferencia(val) {
  if (!val) return '';
  var s = String(val).trim();
  if (s.endsWith('.0')) s = s.slice(0, -2);
  return s.toLowerCase();
}

function fmt(v) {
  return Number(v).toLocaleString('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
}

window.addEventListener('DOMContentLoaded', () => {
  carregarCatalogo(false);
});

function carregarCatalogo(forceUpdate) {
  var url = URL_GOOGLE_SCRIPT + (forceUpdate ? "?atualizar=true" : "");
  
  document.getElementById('grid').innerHTML = Array(8).fill().map(() => `
    <div class="sk-card" style="height:240px; padding:10px;">
      <div class="skeleton" style="height:130px; margin-bottom:10px;"></div>
      <div class="skeleton" style="height:15px; width:40%; margin-bottom:6px;"></div>
      <div class="skeleton" style="height:30px; margin-bottom:8px;"></div>
      <div class="skeleton" style="height:20px; width:60%;"></div>
    </div>
  `).join('');

  fetch(url)
    .then(res => res.json())
    .then(data => {
      catalogo = data;
      pedidoSalvo = false;

      // Alimenta seletor de Marcas dinamicamente com base nas primeiras palavras
      var marcasSet = new Set();
      catalogo.produtos.forEach(p => {
        if(p.descricao) {
          var prime = p.descricao.trim().split(' ')[0].toUpperCase();
          if(prime.length > 2) marcasSet.add(prime);
        }
      });
      var htmlMarca = '<option value="">TODAS</option>';
      marcasSet.forEach(m => { htmlMarca += `<option value="${m}">${m}</option>`; });
      document.getElementById('fil-marca').innerHTML = htmlMarca;

      // Alimenta os seletores de Estado (UF) dinamicamente vindo da aba FRETE
      // O backend envia 'estados' como array de siglas
      var ufs = [];
      if (Array.isArray(catalogo.estados) && catalogo.estados.length > 0) {
        ufs = catalogo.estados.map(e => String(e).toUpperCase().trim()).filter(Boolean).sort();
      } else if (catalogo.fretes) {
        ufs = Object.keys(catalogo.fretes).sort();
      }
      var htmlUf = '<option value="">Selecione o Estado...</option>';
      ufs.forEach(uf => { htmlUf += `<option value="${uf}">${uf}</option>`; });
      document.getElementById('uf-d').innerHTML = htmlUf;
      document.getElementById('uf-m').innerHTML = htmlUf;

      if(catalogo.logoUrl) {
        document.getElementById('logo-area').innerHTML = `<img src="${catalogo.logoUrl}" alt="Logo">`;
      }

      renderizarProdutos(catalogo.produtos);
      atualizarPainel();
    })
    .catch(err => {
      console.error(err);
      document.getElementById('grid').innerHTML = '<div class="vazio" style="grid-column:1/-1">Erro ao carregar catálogo. Certifique-se de que o Script está publicado como Web App para Acesso Anónimo.</div>';
    });
}

function renderizarProdutos(lista) {
  var tabelaAtiva = document.getElementById('icms-d').value;
  var html = '';
  
  if(lista.length === 0) {
    document.getElementById('grid').innerHTML = '<div class="vazio" style="grid-column:1/-1">Nenhum produto encontrado.</div>';
    document.getElementById('cont').textContent = '0 produtos';
    return;
  }

  lista.forEach(p => {
    var ref = normalizarReferencia(p.codigo);
    var qty = cesta[ref] || 0;
    
    var precoUn = p.precos[tabelaAtiva] || p.precos['ICMS ' + tabelaAtiva] || Object.values(p.precos)[0] || 0;
    var badgePromo = '';
    var classePromo = '';
    
    if (p.emPromocao) {
      var prPromo = p.precosPromo[tabelaAtiva] || p.precosPromo['ICMS ' + tabelaAtiva] || Object.values(p.precosPromo)[0];
      if (prPromo) {
        precoUn = prPromo;
        badgePromo = '<div class="card-badge-promo">PROMO</div>';
        classePromo = ' promo';
      }
    }

    var imgHtml = p.fileId ? `<img src="https://drive.google.com/thumbnail?id=${p.fileId}&sz=w300" onload="this.classList.add('loaded')">` : '<span class="no-img-icon">📦</span>';

    html += `
      <div class="card${qty > 0 ? ' sel' : ''}${classePromo}" id="card-${ref}" onclick="abrirModal('${ref}')">
        ${badgePromo}
        <div class="card-badge-qty" id="badge-qty-${ref}" style="${qty > 0 ? 'display:block' : 'display:none'}">${qty}</div>
        <div class="card-img">${imgHtml}</div>
        <div class="card-body">
          <div class="card-cod">${p.codigo}</div>
          <div class="card-desc" title="${p.descricao}">${p.descricao}</div>
          <div class="card-bottom">
            <div class="card-preco">R$ ${fmt(precoUn)}</div>
            <div class="card-emb">Emb: ${p.qtdEmbalagem}</div>
          </div>
        </div>
      </div>
    `;
  });

  document.getElementById('grid').innerHTML = html;
  document.getElementById('cont').textContent = `${lista.length} ${lista.length === 1 ? 'produto' : 'produtos'}`;
}

function filtrar() {
  if(!catalogo.produtos) return;
  var busca = document.getElementById('busca').value.toLowerCase().trim();
  var marca = document.getElementById('fil-marca').value;
  var precoMax = parseFloat(document.getElementById('fil-preco').value) || Infinity;
  var tabelaAtiva = document.getElementById('icms-d').value;

  var filtrados = catalogo.produtos.filter(p => {
    var ref = normalizarReferencia(p.codigo);
    var desc = p.descricao.toLowerCase();
    var ean = (p.codigoEan || '').toLowerCase();
    
    var mBusca = !busca || ref.includes(busca) || desc.includes(busca) || ean.includes(busca);
    var mMarca = !marca || desc.startsWith(marca.toLowerCase()) || desc.includes(' ' + marca.toLowerCase());
    
    var precoUn = p.precos[tabelaAtiva] || p.precos['ICMS ' + tabelaAtiva] || Object.values(p.precos)[0] || 0;
    if(p.emPromocao) {
      precoUn = p.precosPromo[tabelaAtiva] || p.precosPromo['ICMS ' + tabelaAtiva] || precoUn;
    }
    var mPreco = precoUn <= precoMax;

    return mBusca && mMarca && mPreco;
  });

  renderizarProdutos(filtrados);
}

function limFiltros() {
  document.getElementById('busca').value = '';
  document.getElementById('fil-marca').value = '';
  document.getElementById('fil-preco').value = '';
  filtrar();
}

